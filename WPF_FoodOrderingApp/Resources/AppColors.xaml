<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <SolidColorBrush x:Key="PrimaryDarkColor">DarkGoldenRod</SolidColorBrush>
    <SolidColorBrush x:Key="SecondaryDarkColor">GoldenRod</SolidColorBrush>
    <SolidColorBrush x:Key="PrimaryLightColor">LightYellow</SolidColorBrush>

    <SolidColorBrush x:Key="PrimaryLightTextColor">Ivory</SolidColorBrush>
    <SolidColorBrush x:Key="PrimaryDarkTextColor">DarkSlateGray</SolidColorBrush>
    
</ResourceDictionary>