<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:models="clr-namespace:WPF_FoodOrderingApp.Models">

    <DataTemplate x:Key="MenuItemDisplayTemplate" DataType="{x:Type models:MenuItem}">
        <Border Width="120" Height="120" BorderThickness="2" BorderBrush="DarkRed" Margin="30">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="{Binding Type}"
                           FontSize="{StaticResource SmallFontSize}"
                           HorizontalAlignment="Left"/>

                <TextBlock Grid.Row="1" Text="{Binding Name}"
                           FontSize="{StaticResource LargeFontSize}"
                           HorizontalAlignment="Stretch"
                           VerticalAlignment="Center"
                           TextAlignment="Center"
                           TextWrapping="Wrap"/>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{Binding Rating}"
                               FontSize="{StaticResource SmallFontSize}"
                               TextAlignment="Left"/>
                    <TextBlock Grid.Column="1" Text="{Binding Price}"
                               FontSize="{StaticResource SmallFontSize}"
                               TextAlignment="Right"/>
                </Grid>
            </Grid>
        </Border>
    </DataTemplate>

</ResourceDictionary>