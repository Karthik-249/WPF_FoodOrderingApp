<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:models="clr-namespace:WPF_FoodOrderingApp.Models"
                    xmlns:converters="clr-namespace:WPF_FoodOrderingApp.Converters">

    <converters:ItemTypeToImagePathConverter x:Key="ItemTypeToImagePathConverter"/>
    <converters:RatingValueToImagePathConverter x:Key="RatingValueToImagePathConverter"/>

    <DataTemplate x:Key="MenuItemDisplayTemplate" DataType="{x:Type models:MenuItem}">
        <Border Width="120" Height="120" Margin="30"
                BorderThickness="2" CornerRadius="8"
                BorderBrush="DarkRed">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Image Grid.Row="0"
                       Source="{Binding Type, Converter={StaticResource ItemTypeToImagePathConverter}}"
                       Width="16"
                       Height="16"
                       Margin="3 3 0 0"
                       HorizontalAlignment="Left"/>

                <TextBlock Grid.Row="1" Text="{Binding Name}"
                           FontSize="{StaticResource LargeFontSize}"
                           HorizontalAlignment="Stretch"
                           VerticalAlignment="Center"
                           TextAlignment="Center"
                           TextWrapping="Wrap"/>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Image Grid.Column="0"
                           Source="{Binding Rating, Converter={StaticResource RatingValueToImagePathConverter}}"
                           Width="16" Height="16" Margin="3 3 0 3"/>
                    <TextBlock Grid.Column="1" Text="{Binding Rating}"
                               FontSize="{StaticResource SmallFontSize}"
                               Margin="0 3"/>

                    <TextBlock Grid.Column="2"
                               Text="{Binding Price}"
                               TextAlignment="Right"/>
                </Grid>
            </Grid>
        </Border>
    </DataTemplate>

</ResourceDictionary>