<Window x:Class="WPF_FoodOrderingApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPF_FoodOrderingApp"
        mc:Ignorable="d"
        Title="Food Ordering Application" Height="750" Width="1250">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="28"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Food Ordering Application"
                   Style="{StaticResource TitleTextStyle}"/>
        
        <Grid Grid.Row="1" Background="{StaticResource PrimaryLightColor}">
            <TextBlock Text="Views shall be loaded here..."
                       HorizontalAlignment="Stretch" VerticalAlignment="Center"
                       TextAlignment="Center"/>
        </Grid>
        
        <TextBlock Grid.Row="2" Text="** This application is a technology demonstrator for WPF MVVM desktop application development **"
                   Style="{StaticResource StatusTextStyle}"/>
    </Grid>
</Window>
